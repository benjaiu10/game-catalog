---
// Layout.astro - componente de layout base
// Todos los archivos .astro tienen dos partes:
//   1. El "frontmatter" entre los --- (código que corre en el servidor)
//   2. El HTML debajo (lo que se renderiza)

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <!-- <slot /> es donde se inserta el contenido de cada página -->
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
