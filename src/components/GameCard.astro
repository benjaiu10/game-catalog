---
// GameCard.astro - tarjeta reutilizable para cada juego
// Props: las "propiedades" que recibe el componente desde afuera
interface Props {
  title: string;
  genre: string;
  rating: number;
  year: number;
  image: string;
  tags: string[];
}

const { title, genre, rating, year, image, tags } = Astro.props;

// Calculamos el color del rating según el valor
const ratingColor = rating >= 8 ? '#4caf84' : rating >= 6 ? '#f5a623' : '#e05c5c';
---

<article class="game-card" data-genre={genre}>
  <div class="card-image-wrapper">
    <img src={image} alt={`Portada de ${title}`} class="card-image" loading="lazy" />
    <div class="card-rating" style={`color: ${ratingColor}; border-color: ${ratingColor}`}>
      ★ {rating}
    </div>
  </div>
  <div class="card-body">
    <p class="card-year">{year}</p>
    <h3 class="card-title">{title}</h3>
    <div class="card-tags">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  </div>
</article>

<style>
  .game-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform var(--transition), border-color var(--transition);
  }

  .game-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-accent);
  }

  .card-image-wrapper {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface2);
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .game-card:hover .card-image {
    transform: scale(1.05);
  }

  .card-rating {
    position: absolute;
    top: 10px;
    right: 10px;
    background: rgba(15, 15, 19, 0.85);
    border: 1px solid;
    border-radius: 6px;
    padding: 2px 8px;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .card-body {
    padding: 1rem;
  }

  .card-year {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-bottom: 0.2rem;
  }

  .card-title {
    font-family: var(--font-main);
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    font-size: 0.75rem;
    padding: 2px 8px;
    border-radius: 4px;
    background: var(--color-surface2);
    border: 1px solid var(--color-border);
    color: var(--color-muted);
  }
</style>
