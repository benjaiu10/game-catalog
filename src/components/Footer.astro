---
// Footer.astro
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <p class="footer-logo">◈ GameVault</p>
    <p class="footer-text">© {year} — Proyecto para Frontend</p>
  </div>
</footer>

<style>
  .footer {
    margin-top: 5rem;
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-logo {
    font-family: var(--font-main);
    font-weight: 800;
    color: var(--color-accent);
  }

  .footer-text {
    color: var(--color-muted);
    font-size: 0.9rem;
  }
</style>
