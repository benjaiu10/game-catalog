---
// Header.astro - barra de navegación
---

<header class="header">
  <div class="container header-inner">
    <a href="/" class="logo">
      <span class="logo-icon">◈</span>
      <span class="logo-text">GameVault</span>
    </a>
    <nav class="nav">
      <a href="#catalogo" class="nav-link">Catálogo</a>
      <a href="#generos" class="nav-link">Géneros</a>
      <a href="#destacados" class="nav-link">Destacados</a>
    </nav>
    <!-- Botón hamburguesa solo visible en mobile -->
    <button class="menu-btn" id="menuBtn" aria-label="Abrir menú">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
  <!-- Menú mobile que se abre al presionar el botón -->
  <div class="mobile-nav" id="mobileNav">
    <a href="#catalogo" class="mobile-nav-link">Catálogo</a>
    <a href="#generos" class="mobile-nav-link">Géneros</a>
    <a href="#destacados" class="mobile-nav-link">Destacados</a>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(15, 15, 19, 0.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-main);
    font-weight: 800;
    font-size: 1.3rem;
    letter-spacing: -0.5px;
  }

  .logo-icon {
    color: var(--color-accent);
    font-size: 1.4rem;
  }

  .nav {
    display: flex;
    gap: 2rem;
  }

  .nav-link {
    color: var(--color-muted);
    font-size: 0.95rem;
    font-weight: 500;
    transition: color var(--transition);
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  /* Botón hamburguesa */
  .menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 4px;
  }

  .menu-btn span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    border-radius: 2px;
    transition: var(--transition);
  }

  /* Menú mobile */
  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--color-border);
    gap: 0.5rem;
  }

  .mobile-nav-link {
    padding: 0.5rem 0;
    color: var(--color-muted);
    font-size: 1rem;
  }

  .mobile-nav.open {
    display: flex;
  }

  /* Responsive: en pantallas chicas ocultamos el nav y mostramos el botón */
  @media (max-width: 640px) {
    .nav {
      display: none;
    }
    .menu-btn {
      display: flex;
    }
  }
</style>

<script>
  // Este script maneja el menú hamburguesa en mobile
  const btn = document.getElementById('menuBtn');
  const nav = document.getElementById('mobileNav');

  btn?.addEventListener('click', () => {
    // toggles agrega/quita la clase 'open'
    nav?.classList.toggle('open');
  });

  // Cerramos el menú cuando hacemos click en un link
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', () => {
      nav?.classList.remove('open');
    });
  });
</script>
